# Database
DATABASE_URL="postgresql://username:password@localhost:5432/prosets_db?schema=public"

# Auth0 Configuration
AUTH0_DOMAIN="your-auth0-domain.auth0.com"
AUTH0_AUDIENCE="your-api-identifier"
JWT_SECRET="your-jwt-secret-key"

# Stripe Configuration
STRIPE_SECRET_KEY="sk_test_your_stripe_secret_key"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret"
STRIPE_PUBLISHABLE_KEY="pk_test_your_stripe_publishable_key"

# AWS S3 Configuration
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="your-aws-access-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
AWS_S3_PRIVATE_BUCKET="prosets-private-files"
AWS_S3_PUBLIC_BUCKET="prosets-public-previews"

# Application Configuration
NODE_ENV="development"
PORT=3000
API_PREFIX="api/v1"

# Security
CORS_ORIGIN="http://localhost:3001"
RATE_LIMIT_TTL=60
RATE_LIMIT_LIMIT=100

# File Upload Limits
MAX_FILE_SIZE=100000000  # 100MB in bytes
MAX_PREVIEW_SIZE=10000000  # 10MB in bytes

# Download Security
PRESIGNED_URL_EXPIRY=300  # 5 minutes in seconds

# Logging
LOG_LEVEL="info"